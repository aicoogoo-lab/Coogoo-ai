<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512" shape-rendering="geometricPrecision">
  <defs>
    <radialGradient id="coreGlow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#ffffff" stop-opacity="1"/>
      <stop offset="20%" stop-color="#00E5FF" stop-opacity="0.98"/>
      <stop offset="55%" stop-color="#7C3AED" stop-opacity="0.8"/>
      <stop offset="100%" stop-color="#000000" stop-opacity="0"/>
    </radialGradient>

    <radialGradient id="holographicRays" cx="50%" cy="45%" r="70%">
      <stop offset="0%" stop-color="#00E5FF" stop-opacity="0.45"/>
      <stop offset="45%" stop-color="#7C3AED" stop-opacity="0.25"/>
      <stop offset="100%" stop-color="#000000" stop-opacity="0"/>
    </radialGradient>

    <linearGradient id="ringGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#00E5FF" stop-opacity="0.95"/>
      <stop offset="45%" stop-color="#7C3AED" stop-opacity="0.98"/>
      <stop offset="100%" stop-color="#FF00FF" stop-opacity="0.7"/>
    </linearGradient>

    <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="8" result="blur1"/>
      <feGaussianBlur in="SourceGraphic" stdDeviation="16" result="blur2"/>
      <feGaussianBlur in="SourceGraphic" stdDeviation="32" result="blur3"/>
      <feMerge>
        <feMergeNode in="blur3"/>
        <feMergeNode in="blur2"/>
        <feMergeNode in="blur1"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>

    <filter id="softGlow" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="4.5"/>
    </filter>

    <filter id="outerGlow" x="-100%" y="-100%" width="300%" height="300%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="24" result="bigBlur"/>
      <feComposite in="bigBlur" in2="SourceGraphic" operator="over"/>
    </filter>
  </defs>

  <!-- لا خلفية: شفافية كاملة -->
  <rect width="512" height="512" fill="transparent"/>

  <!-- هالة مركزية محسوبة بحيث لا تُقص في الحواف -->
  <circle cx="256" cy="256" r="220" fill="url(#holographicRays)"/>

  <!-- الحلقات الكمومية -->
  <g filter="url(#glow)">
    <ellipse cx="256" cy="256" rx="210" ry="72" fill="none" stroke="url(#ringGradient)" stroke-width="4" opacity="0.85" transform="rotate(-20, 256, 256)"/>
    <ellipse cx="256" cy="256" rx="190" ry="92" fill="none" stroke="url(#ringGradient)" stroke-width="3.5" opacity="0.75" transform="rotate(40, 256, 256)"/>
    <ellipse cx="256" cy="256" rx="172" ry="112" fill="none" stroke="url(#ringGradient)" stroke-width="3" opacity="0.65" transform="rotate(-55, 256, 256)"/>
    <ellipse cx="256" cy="256" rx="154" ry="132" fill="none" stroke="#00E5FF" stroke-width="2.5" opacity="0.6" transform="rotate(15, 256, 256)"/>
  </g>

  <!-- حلقات داخلية -->
  <circle cx="256" cy="256" r="104" fill="none" stroke="#00E5FF" stroke-width="2" opacity="0.7" filter="url(#softGlow)"/>
  <circle cx="256" cy="256" r="82" fill="none" stroke="#7C3AED" stroke-width="2.5" opacity="0.75" filter="url(#softGlow)"/>
  <circle cx="256" cy="256" r="60" fill="none" stroke="#FF00FF" stroke-width="2" opacity="0.6"/>

  <!-- جسيمات طاقة (مركزة أكثر نحو الوسط لتفادي القص) -->
  <g fill="#00E5FF" filter="url(#glow)">
    <circle cx="135" cy="190" r="4.5" opacity="0.9"/>
    <circle cx="375" cy="170" r="4" opacity="0.8"/>
    <circle cx="305" cy="380" r="4.5" opacity="0.95"/>
    <circle cx="400" cy="310" r="5" opacity="0.7"/>
    <circle cx="115" cy="330" r="4" opacity="0.85"/>
    <circle cx="210" cy="395" r="4.5" opacity="0.8"/>
    <circle cx="365" cy="105" r="3.5" opacity="0.7"/>
    <circle cx="145" cy="120" r="4" opacity="0.75"/>
    <circle cx="420" cy="235" r="4.5" opacity="0.8"/>
    <circle cx="180" cy="95" r="4" opacity="0.85"/>
  </g>

  <g fill="#7C3AED" filter="url(#softGlow)">
    <circle cx="225" cy="145" r="4" opacity="0.9"/>
    <circle cx="340" cy="390" r="4.5" opacity="0.8"/>
    <circle cx="120" cy="260" r="4" opacity="0.95"/>
    <circle cx="410" cy="200" r="5" opacity="0.7"/>
    <circle cx="280" cy="110" r="4" opacity="0.85"/>
  </g>

  <!-- النواة -->
  <circle cx="256" cy="256" r="48" fill="url(#coreGlow)" filter="url(#outerGlow)"/>
  <circle cx="256" cy="256" r="38" fill="#ffffff" opacity="0.25" filter="url(#softGlow)"/>
  <circle cx="256" cy="256" r="28" fill="#00E5FF" opacity="0.95" filter="url(#glow)"/>
  <circle cx="256" cy="256" r="14" fill="#ffffff" opacity="1"/>

  <!-- أشعة -->
  <g stroke="#00E5FF" stroke-width="1.1" opacity="0.5" filter="url(#softGlow)">
    <line x1="256" y1="188" x2="256" y2="158"/>
    <line x1="256" y1="324" x2="256" y2="354"/>
    <line x1="188" y1="256" x2="158" y2="256"/>
    <line x1="324" y1="256" x2="354" y2="256"/>
    <line x1="210" y1="210" x2="192" y2="192"/>
    <line x1="302" y1="302" x2="320" y2="320"/>
    <line x1="210" y1="302" x2="192" y2="320"/>
    <line x1="302" y1="210" x2="320" y2="192"/>
  </g>

  <!-- طبقة زجاجية خفيفة -->
  <circle cx="256" cy="256" r="210" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="1.5"/>
</svg>
