  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",

  "background_color": "#050509",
  "theme_color": "#00E5FF",
  "status_bar_color": "#050509",
  "navigation_bar_color": "#050509",

  "lang": "ar",
  "dir": "rtl",

